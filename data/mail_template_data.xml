<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        
        <record id="article_creation" model="mail.template">
            <field name="name">Article SAP: Nouvelle création </field>
            <field name="model_id" ref="article_sap.model_article_article"/>
            <field name="subject">Nouvelle demande de création: {{ object.ref }}</field>
            <field name="email_from">ARMaroc@araymond.com</field>
            <field name="body_html" type="html">
            <div>
                Bonjour, <br/><br/>                
                Une nouvelle demande de création a été lancé pour la référence <strong><t t-out="dict(object._fields['reftype'].selection).get(object.reftype)"></t></strong> <strong><t t-out="object.ref"></t></strong>, cliquez sur le lien suivant pour y accéder: <br/>                
                    <div style="margin: 16px 0px 16px 0px;">
                                <a t-attf-href="https://ma-odoo.ar.ray.group/web#id={{ object.id }}&amp;cids=1&amp;menu_id=226&amp;action=306&amp;model=article.article&amp;view_type=form"
                                    style="background-color: #1481f4; padding: 8px 16px 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;">
                                    Accéder à la demande
                                </a>
                    </div>                            
                Merci,
            </div>
            </field>
        </record>

        <record id="article_modification" model="mail.template">
            <field name="name">Article SAP: Modification </field>
            <field name="model_id" ref="article_sap.model_article_article"/>
            <field name="subject">Nouvelle modification / création sur la demande: {{ object.ref }}</field>
            <field name="email_from">ARMaroc@araymond.com</field>
            <field name="body_html" type="html">
            <div>
                Bonjour, <br/><br/>                
                Une nouvelle modification a été effectuée sur la référence <strong><t t-out="dict(object._fields['reftype'].selection).get(object.reftype)"></t></strong> <strong><t t-out="object.ref"></t></strong>, cliquez sur le lien suivant pour y accéder: <br/>                
                    <div style="margin: 16px 0px 16px 0px;">
                                <a t-attf-href="https://ma-odoo.ar.ray.group/web#id={{ object.id }}&amp;cids=1&amp;menu_id=226&amp;action=306&amp;model=article.article&amp;view_type=form"
                                    style="background-color: #1481f4; padding: 8px 16px 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;">
                                    Accéder à la demande
                                </a>
                    </div>                            
                Merci,
            </div>
            </field>
        </record>

        <record id="article_derogation" model="mail.template">
            <field name="name">Article SAP: Derogation </field>
            <field name="model_id" ref="article_sap.model_article_article"/>
            <field name="subject">Article: {{ object.ref }} créé, statut: Dérogation</field>
            <field name="email_from">ARMaroc@araymond.com</field>
            <field name="body_html" type="html">
            <div>
                Bonjour, <br/><br/>               
                La référence <strong><t t-out="object.ref"></t></strong> a été créée sur SAP. Cependant, sa demande de création est toujours en attente de correction des données. <br/>
                Cliquez sur le lien suivant pour accéder a la demande: <br/>                
                    <div style="margin: 16px 0px 16px 0px;">
                                <a t-attf-href="https://ma-odoo.ar.ray.group/web#id={{ object.id }}&amp;cids=1&amp;menu_id=226&amp;action=306&amp;model=article.article&amp;view_type=form"
                                    style="background-color: #1481f4; padding: 8px 16px 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;">
                                    Accéder à la demande
                                </a>
                    </div>                            
                Merci,
            </div>
            </field>
        </record>

        <record id="article_archive" model="mail.template">
            <field name="name">Article SAP: Archive </field>
            <field name="model_id" ref="article_sap.model_article_article"/>
            <field name="subject">Article {{ object.ref }} créé</field>
            <field name="email_from">ARMaroc@araymond.com</field>
            <field name="body_html" type="html">
            <div>
                Bonjour, <br/><br/>                
                La référence <strong><t t-out="object.ref"></t></strong> a été créée sur SAP. <br/>   
                                           
                Merci,
            </div>
            </field>
        </record>
    </data>
</odoo>
