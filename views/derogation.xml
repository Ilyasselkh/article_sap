<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <record model="ir.actions.act_window" id="action_derogation"> 
            <field name="name">Dérogations</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">article.article</field>
            <field name="domain">[('state', '=', 'derogation')]</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem   id="menu_sap_derogation" name="Attente dérogation"
                    parent="menu_article_root" 
                    action="action_derogation"
                    sequence="40"/>

        <record id="article_der_tree" model="ir.ui.view">
            <field name="name">article.der.tree</field>
            <field name="model">article.article</field>
            <field name="arch" type="xml">
                <list>
                    <field name="ref"/>
                    <field name="reftype"/>
                    <field name="state" />
                    <field name="create_uid" string="Crée par"/>
                    <field name="create_date" string="Crée le"/>
                    <field name="isderogation" widget="boolean_toggle" readonly="1"/>
                    <field name="edit"/>
                </list>
            </field>
        </record>

        
</odoo>

